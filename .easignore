# EAS Build のアップロード対象を制御するファイル。
# .easignore がある場合 EAS は .gitignore の代わりにこれを使う。
# 基本は .gitignore と同一だが、react-native-dotenv(safe:true) が
# ビルド時に読む .env をクラウドビルドへ含めるため末尾で再包含する。

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Native (generated by `expo prebuild`; regenerate instead of committing)
/ios
/android
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# env
.env

# --- EAS 用: .env はクラウドビルドに必要なので再包含 ---
!.env
